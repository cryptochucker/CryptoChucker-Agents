# Exchange (only needed to ENABLE live; paper needs none)
EXCHANGE_API_KEY=
EXCHANGE_API_SECRET=
EXCHANGE_API_PASSWORD=
# Alerts
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DISCORD_WEBHOOK_URL=
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL_TO=
# Optional LLM co-pilot (OFF by default)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# Live trading gate values (for FUTURE wiring only -- live execution is NOT wired in this release).
# When live order placement is wired, it will require BOTH of the following exact values:
#   PAPER_TRADING=false          (NOT "true" or any other string)
#   ENABLE_LIVE_TRADING=true     (NOT "false" or any other string)
# Until then these env vars govern only credential/client construction and the _live_order guard;
# Executor.on_signal() always uses the paper-fill path in this release.
PAPER_TRADING=true
ENABLE_LIVE_TRADING=false
